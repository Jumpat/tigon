{
    "models": {
        "denoiser": {
            "name": "SparseStructureFlowMixCondModel",
            "args": {
                "resolution": 16,
                "in_channels": 8,
                "out_channels": 8,
                "model_channels": 1024,
                "cond_channels": 1024,
                "cond_channels_txt": 768,
                "num_blocks": 24,
                "num_heads": 16,
                "mlp_ratio": 4,
                "patch_size": 1,
                "pe_mode": "ape",
                "qk_rms_norm": true,
                "use_fp16": true,
                "use_bridge": true,
                "pretrained_path":"/opt/huawei/explorer-env/dataset/trellis_ckpt/cenjiazhong/TRELLIS/./mix_trellis_pipe/ckpts/mix_trellis_ss_flow.safetensors",
                "freeze_pretrained": false
            }
        }
    },
    "dataset": {
        "name": "InterleaveConditionedSparseStructureLatent",
        "args": {
            "latent_model": "ss_enc_conv3d_16l8_fp16",
            "min_aesthetic_score": 4.5,
            "image_size": 518,
            "pretrained_ss_dec": "/opt/huawei/explorer-env/dataset/trellis_ckpt/zhouzanwei/projects/TRELLIS-origin/ckpts/TRELLIS/ss_dec_conv3d_16l8_fp16"
        }
    },
    "trainer": {
        "name": "InterleaveConditionedDINOCLIPFlowMatchingCFGTrainer",
        "args": {
            "use_deepspeed": true,
            "deepspeed_config": "./configs/ds_config_zero2.json",
            "max_steps": 55000,
            "batch_size_per_gpu": 8,
            "batch_split": 4,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 0.00001,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "deepspeed",
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 500,
            "i_print": 1000,
            "i_sample": 10000,
            "i_save": 3000,
            "image_uncond": 0.5,
            "text_uncond": 0.5,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": 1.0,
                    "std": 1.0
                }
            },
            "sigma_min": 1e-5,
            "image_cond_model": "dinov2_vitl14_reg",
            "txt_cond_model": "/opt/huawei/explorer-env/dataset/trellis_ckpt/cache/huggingface/hub/clip-vit-large-patch14/"
        }
    }
}